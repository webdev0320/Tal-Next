# 1. FIX MIME TYPES FOR NEXT.JS MODULES
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType application/javascript .mjs
</IfModule>

# 2. NEXT.JS STATIC ROUTING
RewriteEngine On

# Remove trailing slashes if necessary, or let Next.js handle them
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# If the requested path is a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If someone visits /about, look for /about/index.html internally
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.*)$ $1.html [L]

# Fallback to 404 page generated by Next.js if the path doesn't exist
ErrorDocument 404 /404/index.html